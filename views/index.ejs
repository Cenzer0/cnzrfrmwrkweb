          <button onclick="copyCode('npx cnzr new my-app')" class="text-xs text-pixel-cyan hover:text-pixel-yellow transition-colors">
            Copy
          </button>
        </div>
        <div class="p-8 text-left">
          <div class="font-mono text-base space-y-2">
            <div>
              <span class="text-pixel-lime">$</span>
              <span class="text-pixel-white ml-2">npx cnzr new my-app</span>
            </div>
            <div class="text-pixel-gray">
