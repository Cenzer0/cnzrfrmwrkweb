        </div>
        <div class="p-8 overflow-x-auto">
          <pre class="text-base leading-relaxed"><code><span class="text-pixel-pink">import</span> { <span class="text-pixel-cyan">CenzeroApp</span> } <span class="text-pixel-pink">from</span> <span class="text-pixel-lime">'cnzr'</span>;

<span class="text-pixel-pink">const</span> <span class="text-pixel-white">app</span> = <span class="text-pixel-pink">new</span> <span class="text-pixel-yellow">CenzeroApp</span>();

<span class="text-pixel-gray">// Modern context API</span>
app.<span class="text-pixel-cyan">get</span>(<span class="text-pixel-lime">'/'</span>, (<span class="text-pixel-white">ctx</span>) => {
  <span class="text-pixel-pink">return</span> ctx.<span class="text-pixel-yellow">json</span>({ 
    <span class="text-pixel-cyan">message</span>: <span class="text-pixel-lime">'Hello CNZR!'</span> 
  });
});

app.<span class="text-pixel-cyan">listen</span>(<span class="text-pixel-yellow">3000</span>);</code></pre>
        </div>
      </div>
    </div>
  </section>

