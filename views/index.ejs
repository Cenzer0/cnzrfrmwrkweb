        </a>
        <a href="https://github.com/CenZero/cnzr" target="_blank" class="btn-pixel-outline hover-lift">
          View on GitHub
        </a>
      </div>

      <!-- Terminal Demo -->
      <div class="terminal max-w-3xl mx-auto hover-lift">
        <div class="bg-pixel-dark/80 px-6 py-4 border-b border-pixel-gray/30 flex items-center justify-between">
