<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'CNZR Framework' %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/output.css">
</head>
<body class="scanline">
  
  <!-- Pixel Art Background -->
  <div class="fixed inset-0 opacity-5 pointer-events-none">
    <div class="absolute top-10 left-10 w-32 h-32 bg-pixel-cyan animate-pixel-float"></div>
    <div class="absolute top-40 right-20 w-24 h-24 bg-pixel-pink animate-pixel-float" style="animation-delay: 0.5s;"></div>
    <div class="absolute bottom-20 left-1/4 w-40 h-40 bg-pixel-purple animate-pixel-float" style="animation-delay: 1s;"></div>
  </div>

  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-pixel-dark/95 backdrop-blur-sm border-b-4 border-pixel-purple">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-pixel-purple border-2 border-pixel-pink flex items-center justify-center animate-bounce-slow">
            <span class="text-pixel-yellow font-pixel text-xl">C</span>
          </div>
          <span class="font-pixel text-xl neon-text">CNZR</span>
        </div>
        
        <div class="hidden md:flex space-x-6 font-pixel text-xs">
          <a href="/" class="text-pixel-cyan hover:text-pixel-yellow transition-colors">HOME</a>
          <a href="/docs" class="text-pixel-white hover:text-pixel-yellow transition-colors">DOCS</a>
          <a href="/playground" class="text-pixel-white hover:text-pixel-yellow transition-colors">PLAY</a>
          <a href="https://github.com/CenZero/cnzr" target="_blank" class="text-pixel-white hover:text-pixel-yellow transition-colors">GITHUB</a>
        </div>
        
        <button class="md:hidden text-pixel-cyan text-2xl">☰</button>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="max-w-6xl mx-auto text-center">
      
      <!-- Pixel Art Character -->
      <div class="mb-8 flex justify-center">
        <div class="relative">
          <div class="w-32 h-32 bg-pixel-purple border-4 border-pixel-pink shadow-pixel animate-pixel-float">
            <div class="absolute top-6 left-6 w-4 h-4 bg-pixel-cyan"></div>
            <div class="absolute top-6 right-6 w-4 h-4 bg-pixel-cyan"></div>
            <div class="absolute bottom-8 left-8 w-16 h-2 bg-pixel-pink"></div>
          </div>
        </div>
      </div>

      <h1 class="font-pixel text-4xl md:text-6xl mb-6 animate-fade-in">
        <span class="neon-text">CNZR</span>
        <br>
        <span class="text-pixel-yellow text-2xl md:text-4xl">FRAMEWORK</span>
      </h1>
      
      <p class="text-pixel-white text-sm md:text-base mb-8 max-w-2xl mx-auto leading-relaxed">
        A modern, minimalist yet powerful Node.js web framework.<br>
        Built with TypeScript. Fast, developer-friendly, feature-rich.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
        <a href="/docs" class="pixel-btn">
          START QUEST
        </a>
        <a href="https://github.com/CenZero/cnzr" target="_blank" class="pixel-btn-secondary">
          VIEW SOURCE
        </a>
      </div>
      
      <!-- Terminal Box -->
      <div class="max-w-2xl mx-auto pixel-card p-6 text-left">
        <div class="flex items-center justify-between mb-4">
          <div class="flex space-x-2">
            <div class="w-3 h-3 bg-pixel-pink"></div>
            <div class="w-3 h-3 bg-pixel-yellow"></div>
            <div class="w-3 h-3 bg-pixel-lime"></div>
          </div>
          <span class="font-pixel text-xs text-pixel-gray">terminal.sh</span>
        </div>
        <div class="font-mono text-sm">
          <span class="text-pixel-lime">$</span>
          <span class="text-pixel-white"> npx cnzr new my-app</span>
          <span class="animate-blink text-pixel-cyan">█</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-16 px-4 bg-pixel-dark/50">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="pixel-card p-6 text-center">
          <div class="font-pixel text-3xl text-pixel-cyan mb-2">2.5.2</div>
          <div class="text-pixel-gray text-xs">VERSION</div>
        </div>
        <div class="pixel-card p-6 text-center">
          <div class="font-pixel text-3xl text-pixel-yellow mb-2">10K+</div>
          <div class="text-pixel-gray text-xs">DOWNLOADS</div>
        </div>
        <div class="pixel-card p-6 text-center">
          <div class="font-pixel text-3xl text-pixel-pink mb-2">500+</div>
          <div class="text-pixel-gray text-xs">STARS</div>
        </div>
        <div class="pixel-card p-6 text-center">
          <div class="font-pixel text-3xl text-pixel-lime mb-2">15+</div>
          <div class="text-pixel-gray text-xs">CONTRIBUTORS</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-pixel text-3xl md:text-4xl neon-text mb-4">FEATURES</h2>
        <p class="text-pixel-gray">Power-ups for your web app</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature Cards -->
        <div class="pixel-card p-6 group">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="font-pixel text-sm text-pixel-cyan mb-3">ROUTING</h3>
          <p class="text-pixel-white text-sm leading-relaxed">
            File-based routing with dynamic params [id] and catch-all [...slug]
          </p>
        </div>
        
        <div class="pixel-card p-6 group">
          <div class="text-4xl mb-4">🔌</div>
          <h3 class="font-pixel text-sm text-pixel-yellow mb-3">PLUGINS</h3>
          <p class="text-pixel-white text-sm leading-relaxed">
            Hook-based plugin system with onRequest, onResponse, onError
          </p>
        </div>
        
        <div class="pixel-card p-6 group">
          <div class="text-4xl mb-4">📘</div>
          <h3 class="font-pixel text-sm text-pixel-pink mb-3">TYPESCRIPT</h3>
          <p class="text-pixel-white text-sm leading-relaxed">
            First-class TypeScript support with full type safety
          </p>
        </div>
        
        <div class="pixel-card p-6 group">
          <div class="text-4xl mb-4">🍪</div>
          <h3 class="font-pixel text-sm text-pixel-lime mb-3">SESSION</h3>
          <p class="text-pixel-white text-sm leading-relaxed">
            Built-in session & cookie management with secure defaults
          </p>
        </div>
        
        <div class="pixel-card p-6 group">
          <div class="text-4xl mb-4">🔒</div>
          <h3 class="font-pixel text-sm text-pixel-cyan mb-3">SECURITY</h3>
          <p class="text-pixel-white text-sm leading-relaxed">
            CORS, security headers, and request validation included
          </p>
        </div>
        
        <div class="pixel-card p-6 group">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="font-pixel text-sm text-pixel-yellow mb-3">PERFORMANCE</h3>
          <p class="text-pixel-white text-sm leading-relaxed">
            Response compression, caching, and optimization built-in
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Code Example Section -->
  <section class="py-20 px-4 bg-pixel-dark/50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-pixel text-3xl md:text-4xl neon-text mb-4">CODE SAMPLES</h2>
        <p class="text-pixel-gray">Simple & powerful API</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Code Block 1 -->
        <div class="pixel-card overflow-hidden">
          <div class="bg-pixel-purple/50 px-4 py-3 border-b-2 border-pixel-gray flex items-center justify-between">
            <span class="font-pixel text-xs text-pixel-yellow">basic.js</span>
            <button onclick="copyCode('code1')" class="text-pixel-cyan hover:text-pixel-yellow text-xs">COPY</button>
          </div>
          <div class="p-4 overflow-x-auto">
            <pre id="code1" class="text-sm"><code><span class="text-pixel-pink">import</span> { <span class="text-pixel-cyan">CenzeroApp</span> } <span class="text-pixel-pink">from</span> <span class="text-pixel-lime">'cnzr'</span>;

<span class="text-pixel-pink">const</span> <span class="text-pixel-white">app</span> = <span class="text-pixel-pink">new</span> <span class="text-pixel-yellow">CenzeroApp</span>();

<span class="text-pixel-gray">// Modern context API</span>
app.<span class="text-pixel-cyan">get</span>(<span class="text-pixel-lime">'/'</span>, (<span class="text-pixel-white">ctx</span>) => {
  <span class="text-pixel-pink">return</span> ctx.<span class="text-pixel-yellow">json</span>({ 
    <span class="text-pixel-cyan">message</span>: <span class="text-pixel-lime">'Hello!'</span> 
  });
});

app.<span class="text-pixel-cyan">listen</span>(<span class="text-pixel-yellow">3000</span>);</code></pre>
          </div>
        </div>
        
        <!-- Code Block 2 -->
        <div class="pixel-card overflow-hidden">
          <div class="bg-pixel-purple/50 px-4 py-3 border-b-2 border-pixel-gray flex items-center justify-between">
            <span class="font-pixel text-xs text-pixel-yellow">routes/[id].js</span>
            <button onclick="copyCode('code2')" class="text-pixel-cyan hover:text-pixel-yellow text-xs">COPY</button>
          </div>
          <div class="p-4 overflow-x-auto">
            <pre id="code2" class="text-sm"><code><span class="text-pixel-gray">// File-based routing</span>
<span class="text-pixel-pink">export async function</span> <span class="text-pixel-yellow">GET</span>(<span class="text-pixel-white">ctx</span>) {
  <span class="text-pixel-pink">const</span> <span class="text-pixel-white">id</span> = ctx.params.<span class="text-pixel-cyan">id</span>;
  
  <span class="text-pixel-pink">return</span> ctx.<span class="text-pixel-yellow">json</span>({ 
    <span class="text-pixel-cyan">user</span>: { id } 
  });
}

<span class="text-pixel-pink">export async function</span> <span class="text-pixel-yellow">POST</span>(<span class="text-pixel-white">ctx</span>) {
  <span class="text-pixel-pink">const</span> <span class="text-pixel-white">data</span> = ctx.<span class="text-pixel-cyan">body</span>;
  <span class="text-pixel-pink">return</span> ctx.<span class="text-pixel-yellow">json</span>({ data });
}</code></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/docs" class="pixel-card p-8 text-center group">
          <div class="text-5xl mb-4">📚</div>
          <h3 class="font-pixel text-sm text-pixel-cyan mb-2">DOCUMENTATION</h3>
          <p class="text-pixel-gray text-sm">Complete guide & API reference</p>
        </a>
        
        <a href="/playground" class="pixel-card p-8 text-center group">
          <div class="text-5xl mb-4">🎮</div>
          <h3 class="font-pixel text-sm text-pixel-yellow mb-2">PLAYGROUND</h3>
          <p class="text-pixel-gray text-sm">Try CNZR in your browser</p>
        </a>
        
        <a href="https://github.com/CenZero/cnzr" target="_blank" class="pixel-card p-8 text-center group">
          <div class="text-5xl mb-4">⭐</div>
          <h3 class="font-pixel text-sm text-pixel-pink mb-2">GITHUB</h3>
          <p class="text-pixel-gray text-sm">Star & contribute</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-pixel-dark border-t-4 border-pixel-purple py-12 px-4">
    <div class="max-w-7xl mx-auto text-center">
      <div class="flex justify-center items-center space-x-4 mb-6">
        <div class="w-12 h-12 bg-pixel-purple border-2 border-pixel-pink flex items-center justify-center">
          <span class="text-pixel-yellow font-pixel text-xl">C</span>
        </div>
        <span class="font-pixel text-xl neon-text">CNZR</span>
      </div>
      
      <p class="text-pixel-gray text-sm mb-4">
        Built with ❤️ by Muhammad Falih Afiq
      </p>
      
      <div class="flex justify-center space-x-6 font-pixel text-xs">
        <a href="https://github.com/CenZero/cnzr" target="_blank" class="text-pixel-cyan hover:text-pixel-yellow">GITHUB</a>
        <a href="/docs" class="text-pixel-cyan hover:text-pixel-yellow">DOCS</a>
        <a href="#" class="text-pixel-cyan hover:text-pixel-yellow">LICENSE</a>
      </div>
      
      <div class="mt-8 text-pixel-gray text-xs">
        <p>© 2024 CNZR Framework • MIT License</p>
      </div>
    </div>
  </footer>

  <script>
    function copyCode(id) {
      const code = document.getElementById(id).textContent;
      navigator.clipboard.writeText(code);
      alert('Code copied to clipboard!');
    }
    
    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  </script>
</body>
</html>
