          <h4 class="font-bold text-pixel-white mb-4 uppercase tracking-wider text-sm">Community</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="/community" class="text-pixel-gray hover:text-pixel-cyan transition-colors">Join Community</a></li>
            <li><a href="https://github.com/CenZero/cnzr/discussions" target="_blank" rel="noopener noreferrer" class="text-pixel-gray hover:text-pixel-cyan transition-colors">Discussions</a></li>
            <li><a href="https://github.com/CenZero/cnzr" target="_blank" rel="noopener noreferrer" class="text-pixel-gray hover:text-pixel-cyan transition-colors">GitHub</a></li>
          </ul>
