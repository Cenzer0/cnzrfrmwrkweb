  <script src="/app-motion.js" defer></script>
  <script>
    // Request history storage
    let requestHistory = [];
    let savedRequests = JSON.parse(localStorage.getItem('cnzr_saved_requests') || '[]');
    
    // Load history from localStorage on page load
    function loadHistoryFromStorage() {
      const stored = localStorage.getItem('cnzr_request_history');
      if (stored) {
        requestHistory = JSON.parse(stored);
        renderHistory();
      }
    }
    
    // Save history to localStorage
    function saveHistoryToStorage() {
      localStorage.setItem('cnzr_request_history', JSON.stringify(requestHistory));
    }
    
    // Tab switching
    function switchTab(tab) {
      document.getElementById('tab-body').classList.remove('text-pixel-cyan', 'border-pixel-cyan');
      document.getElementById('tab-body').classList.add('text-pixel-gray', 'border-transparent');
      document.getElementById('tab-headers').classList.remove('text-pixel-cyan', 'border-pixel-cyan');
      document.getElementById('tab-headers').classList.add('text-pixel-gray', 'border-transparent');
      
      if (tab === 'body') {
        document.getElementById('tab-body').classList.add('text-pixel-cyan', 'border-pixel-cyan');
        document.getElementById('response-body-container').classList.remove('hidden');
        document.getElementById('response-headers-container').classList.add('hidden');
      } else {
        document.getElementById('tab-headers').classList.add('text-pixel-cyan', 'border-pixel-cyan');
        document.getElementById('response-body-container').classList.add('hidden');
        document.getElementById('response-headers-container').classList.remove('hidden');
      }
    }
    
    // Update method color
    function updateMethodColor() {
      const method = document.getElementById('method').value;
      const select = document.getElementById('method');
      select.className = 'w-full bg-pixel-dark border-2 text-pixel-white px-4 py-3 rounded focus:outline-none transition-colors ';
      
      if (method === 'GET') select.className += 'border-pixel-cyan/30 focus:border-pixel-cyan';
      else if (method === 'POST') select.className += 'border-pixel-yellow/30 focus:border-pixel-yellow';
      else if (method === 'PUT') select.className += 'border-pixel-pink/30 focus:border-pixel-pink';
      else if (method === 'PATCH') select.className += 'border-pixel-lime/30 focus:border-pixel-lime';
      else select.className += 'border-pixel-gray/30 focus:border-pixel-gray';
    }
    
    // Load example
    function loadExample(type) {
      const examples = {
        health: {
          method: 'GET',
          endpoint: '/health',
          headers: '',
          body: ''
        },
        stats: {
          method: 'GET',
          endpoint: '/api/stats',
          headers: '',
          body: ''
        },
        features: {
          method: 'GET',
          endpoint: '/api/features',
          headers: '',
          body: ''
        },
        feedback: {
          method: 'POST',
          endpoint: '/api/feedback',
          headers: JSON.stringify({
            "Content-Type": "application/json"
          }, null, 2),
          body: JSON.stringify({
            name: "Developer",
            message: "Great framework!"
          }, null, 2)
        }
      };
      
      const example = examples[type];
      document.getElementById('method').value = example.method;
      document.getElementById('endpoint').value = example.endpoint;
      document.getElementById('headers').value = example.headers;
      document.getElementById('requestBody').value = example.body;
      updateMethodColor();
    }
    
    // Send request
    async function sendRequest() {
      const method = document.getElementById('method').value;
      const endpoint = document.getElementById('endpoint').value;
      const headersText = document.getElementById('headers').value;
      const body = document.getElementById('requestBody').value;
      
      const startTime = Date.now();
      
      try {
        const options = {
          method: method,
          headers: {
            'Content-Type': 'application/json'
          }
        };
        
        // Parse custom headers
        if (headersText.trim()) {
          try {
            const customHeaders = JSON.parse(headersText);
            Object.assign(options.headers, customHeaders);
          } catch (e) {
            showToast('Invalid headers JSON', 'error');
            return;
          }
        }
        
        if (body && method !== 'GET') {
          options.body = body;
        }
        
        const response = await fetch(endpoint, options);
        const data = await response.json();
        const endTime = Date.now();
        const duration = endTime - startTime;
        
        // Calculate response size
        const size = new Blob([JSON.stringify(data)]).size;
        const sizeText = size < 1024 ? `${size} B` : `${(size / 1024).toFixed(2)} KB`;
        
        // Update status
        const statusEl = document.getElementById('statusCode');
        statusEl.textContent = response.status;
        statusEl.className = `px-3 py-2 rounded text-sm block text-center ${
          response.ok ? 'bg-pixel-lime/20 text-pixel-lime' : 'bg-pixel-pink/20 text-pixel-pink'
        }`;
        
        // Update time and size
        document.getElementById('responseTime').textContent = `${duration}ms`;
        document.getElementById('responseSize').textContent = sizeText;
        
        // Update response body
        document.getElementById('responseBody').textContent = JSON.stringify(data, null, 2);
        
        // Update response headers
        const headersObj = {};
        response.headers.forEach((value, key) => {
          headersObj[key] = value;
        });
        document.getElementById('responseHeaders').textContent = JSON.stringify(headersObj, null, 2);
        
        // Add to history
        addToHistory(method, endpoint, response.status, duration);
        
        showToast('Request completed successfully', 'success');
        
      } catch (error) {
        document.getElementById('statusCode').textContent = 'Error';
        document.getElementById('statusCode').className = 'px-3 py-2 bg-pixel-pink/20 text-pixel-pink rounded text-sm block text-center';
        document.getElementById('responseBody').textContent = `Error: ${error.message}`;
        showToast(`Error: ${error.message}`, 'error');
      }
    }
    
    // Add to history
    function addToHistory(method, endpoint, status, duration) {
      const timestamp = new Date().toLocaleTimeString();
      requestHistory.unshift({ method, endpoint, status, duration, timestamp });
      
      if (requestHistory.length > 10) {
        requestHistory = requestHistory.slice(0, 10);
      }
      
      saveHistoryToStorage();
      renderHistory();
    }
    
    // Render history
    function renderHistory() {
      const historyEl = document.getElementById('history');
      
      if (requestHistory.length === 0) {
        historyEl.innerHTML = '<p class="text-sm text-pixel-gray text-center py-4">No requests yet</p>';
        return;
      }
      
      historyEl.innerHTML = requestHistory.map(item => {
        const statusColor = item.status < 400 ? 'text-pixel-lime' : 'text-pixel-pink';
        const methodColor = item.method === 'GET' ? 'text-pixel-cyan' : 'text-pixel-yellow';
        
        return `
          <div class="p-3 bg-pixel-dark/30 rounded text-xs hover:bg-pixel-dark/50 transition-colors cursor-pointer" onclick="loadFromHistory('${item.endpoint}', '${item.method}')">
            <div class="flex items-center justify-between mb-1">
              <span class="${methodColor} font-bold">${item.method}</span>
              <span class="${statusColor}">${item.status}</span>
            </div>
            <div class="text-pixel-gray truncate">${item.endpoint}</div>
            <div class="text-pixel-gray/60 mt-1">${item.timestamp} • ${item.duration}ms</div>
          </div>
        `;
      }).join('');
    }
    
    // Load from history
    function loadFromHistory(endpoint, method) {
      document.getElementById('endpoint').value = endpoint;
      document.getElementById('method').value = method;
      updateMethodColor();
    }
    
    // Clear history
    function clearHistory() {
      requestHistory = [];
      saveHistoryToStorage();
      renderHistory();
      showToast('History cleared', 'success');
    }
    
    // Save request
    function saveRequest() {
      const name = prompt('Enter a name for this request:');
      if (!name) return;
      
      const request = {
        id: Date.now(),
        name: name,
        method: document.getElementById('method').value,
        endpoint: document.getElementById('endpoint').value,
        headers: document.getElementById('headers').value,
        body: document.getElementById('requestBody').value,
        savedAt: new Date().toLocaleString()
      };
      
      savedRequests.push(request);
      localStorage.setItem('cnzr_saved_requests', JSON.stringify(savedRequests));
      showToast(`Request "${name}" saved!`, 'success');
    }
    
    // Show saved requests
    function showSavedRequests() {
      if (savedRequests.length === 0) {
        showToast('No saved requests', 'error');
        return;
      }
      
      const modal = document.createElement('div');
      modal.className = 'fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4';
      modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
      
      const content = document.createElement('div');
      content.className = 'card-pixel p-6 max-w-2xl w-full max-h-[80vh] overflow-y-auto';
      content.onclick = (e) => e.stopPropagation();
      
      content.innerHTML = `
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-2xl font-bold text-pixel-cyan">Saved Requests</h3>
          <button onclick="this.closest('.fixed').remove()" class="text-pixel-gray hover:text-pixel-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="space-y-3">
          ${savedRequests.map(req => `
            <div class="p-4 bg-pixel-dark/50 rounded border border-pixel-gray/30 hover:border-pixel-cyan/50 transition-colors">
              <div class="flex items-start justify-between mb-2">
                <div class="flex-1">
                  <h4 class="font-bold text-pixel-white mb-1">${req.name}</h4>
                  <div class="flex items-center gap-2 text-xs">
                    <span class="px-2 py-1 bg-pixel-cyan/20 text-pixel-cyan rounded">${req.method}</span>
                    <span class="text-pixel-gray">${req.endpoint}</span>
                  </div>
                  <p class="text-xs text-pixel-gray/60 mt-1">Saved: ${req.savedAt}</p>
                </div>
                <div class="flex gap-2">
                  <button onclick="loadSavedRequest(${req.id}); this.closest('.fixed').remove();" class="px-3 py-1 bg-pixel-cyan/20 text-pixel-cyan rounded text-xs hover:bg-pixel-cyan/30 transition-colors">
                    Load
                  </button>
                  <button onclick="deleteSavedRequest(${req.id}); this.closest('.fixed').remove(); showSavedRequests();" class="px-3 py-1 bg-pixel-pink/20 text-pixel-pink rounded text-xs hover:bg-pixel-pink/30 transition-colors">
                    Delete
                  </button>
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      `;
      
      modal.appendChild(content);
      document.body.appendChild(modal);
    }
    
    // Load saved request
    function loadSavedRequest(id) {
      const request = savedRequests.find(r => r.id === id);
      if (!request) return;
      
      document.getElementById('method').value = request.method;
      document.getElementById('endpoint').value = request.endpoint;
      document.getElementById('headers').value = request.headers;
      document.getElementById('requestBody').value = request.body;
      updateMethodColor();
      showToast(`Loaded "${request.name}"`, 'success');
    }
    
    // Delete saved request
    function deleteSavedRequest(id) {
      savedRequests = savedRequests.filter(r => r.id !== id);
      localStorage.setItem('cnzr_saved_requests', JSON.stringify(savedRequests));
      showToast('Request deleted', 'success');
    }
    
    // Generate cURL command
    function generateCurl() {
      const method = document.getElementById('method').value;
      const endpoint = document.getElementById('endpoint').value;
      const headersText = document.getElementById('headers').value;
      const body = document.getElementById('requestBody').value;
      
      const baseUrl = window.location.origin;
      let curl = `curl -X ${method} "${baseUrl}${endpoint}"`;
      
      // Add headers
      curl += ` \\\n  -H "Content-Type: application/json"`;
      
      if (headersText.trim()) {
        try {
          const headers = JSON.parse(headersText);
          Object.entries(headers).forEach(([key, value]) => {
            curl += ` \\\n  -H "${key}: ${value}"`;
          });
        } catch (e) {
          showToast('Invalid headers JSON', 'error');
          return;
        }
      }
      
      // Add body
      if (body && method !== 'GET') {
        const escapedBody = body.replace(/"/g, '\\"').replace(/\n/g, '');
        curl += ` \\\n  -d "${escapedBody}"`;
      }
      
      // Show modal with cURL command
      const modal = document.createElement('div');
      modal.className = 'fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4';
      modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
      
      const content = document.createElement('div');
      content.className = 'card-pixel p-6 max-w-3xl w-full';
      content.onclick = (e) => e.stopPropagation();
      
      content.innerHTML = `
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-2xl font-bold text-pixel-cyan">cURL Command</h3>
          <button onclick="this.closest('.fixed').remove()" class="text-pixel-gray hover:text-pixel-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="terminal">
          <div class="bg-pixel-dark/80 px-6 py-4 border-b border-pixel-gray/30 flex items-center justify-between">
            <span class="text-xs text-pixel-gray font-mono">curl</span>
            <button onclick="copyCurl()" class="text-xs text-pixel-cyan hover:text-pixel-yellow transition-colors">Copy</button>
          </div>
          <div class="p-6 overflow-x-auto">
            <pre id="curlCommand" class="text-sm text-pixel-lime font-mono whitespace-pre-wrap">${curl}</pre>
          </div>
        </div>
        <p class="text-xs text-pixel-gray mt-4">Copy this command and run it in your terminal</p>
      `;
      
      modal.appendChild(content);
      document.body.appendChild(modal);
    }
    
    // Copy cURL command
    function copyCurl() {
      const curlText = document.getElementById('curlCommand').textContent;
      navigator.clipboard.writeText(curlText).then(() => {
        showToast('cURL command copied!', 'success');
      });
    }
    
    // Clear history
    function clearHistory() {
      requestHistory = [];
      renderHistory();
      showToast('History cleared', 'success');
    }
    
    // Copy response
    function copyResponse() {
      const responseText = document.getElementById('responseBody').textContent;
      navigator.clipboard.writeText(responseText).then(() => {
        showToast('Response copied to clipboard!', 'success');
      });
    }
    
    // Show toast
    function showToast(message, type = 'success') {
      const toast = document.createElement('div');
      const bgColor = type === 'success' ? 'bg-pixel-cyan' : 'bg-pixel-pink';
      toast.className = `fixed bottom-4 right-4 ${bgColor} text-pixel-dark px-6 py-3 rounded-lg font-semibold shadow-lg z-50`;
      toast.textContent = message;
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(20px)';
      toast.style.transition = 'all 0.3s ease';
      document.body.appendChild(toast);
      
      requestAnimationFrame(() => {
        toast.style.opacity = '1';
        toast.style.transform = 'translateY(0)';
      });
      
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(20px)';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }
    
    // Load default example on page load
    document.addEventListener('DOMContentLoaded', () => {
      loadExample('health');
      updateMethodColor();
      loadHistoryFromStorage();
    });
  </script>
</body>
</html>
